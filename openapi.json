            example: Bearer 6342c1c05305301c15027f131888
          in: header
          name: Authorization
          required: true
          description: Bearer 92e412b547de88dc66368a21e4ebb56d0f813c1a
      tags:
        - Folders
      x-internal: false
    parameters:
